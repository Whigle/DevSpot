@using DevSpot.Constants
@using DevSpot.ViewModels
@model JobPostingsListViewModel

<h1 class="text-center m-5">All Developer Jobs</h1>

<form method="get" asp-action="Index" class="mb-4">
	<div class="row g-2">
		<div class="col-md-4">
			<input type="text" name="searchTitle" class="form-control" placeholder="Search by title..." value="@Model.Filters.SearchTitle" />
		</div>
		<div class="col-md-3">
			<input type="text" name="location" class="form-control" placeholder="Location..." value="@Model.Filters.Location" />
		</div>
		<div class="col-md-2">
			<select name="workType" class="form-select">
				<option value="">All types</option>
				@foreach (var workType in Enum.GetValues<WorkType>())
				{
					if (Model.Filters.WorkType == workType)
					{
						<option value="@workType" selected>@workType</option>
					}
					else
					{
						<option value="@workType">@workType</option>
					}
				}
			</select>
		</div>
		<div class="col-md-2">
			@{
				var sortBy = Model.Filters.SortBy ?? "date_desc";
			}
			<select name="sortBy" class="form-select">
				<option value="date_desc" selected="@(sortBy == "date_desc" ? "selected" : null)">
					Newest first
				</option>
				<option value="date_asc" selected="@(sortBy == "date_asc" ? "selected" : null)">
					Oldest first
				</option>
			</select>
		</div>
		<div class="col-md-1">
			<button type="submit" class="btn btn-primary w-100">Filter</button>
		</div>
	</div>
	<input type="hidden" name="page" value="1" />
</form>

<div class="list-group">
	@foreach (var jobPosting in Model.Items)
	{
		<div class="list-group-item" id="job-posting-@jobPosting.Id">
			<h3>@jobPosting.Title</h3>
			<p>@jobPosting.WorkType</p>
			<p>@jobPosting.Description</p>
			<p><strong>Company:</strong>@jobPosting.Company</p>
			<p><strong>Location:</strong>@jobPosting.Location</p>
			<p><strong>Posted Date:</strong>@jobPosting.PostedDate.ToShortDateString()</p>

			@if (User.IsInRole(Roles.ADMIN) || User.IsInRole(Roles.EMPLOYER))
			{
				<div>
					<button onclick="deleteJobPosting(@jobPosting.Id)" class="btn btn-sm btn-danger">Delete</button>
				</div>
			}
		</div>
	}
</div>
<nav aria-label="Job postings pages" class="mt-3">
	<ul class="pagination justify-content-center">
		<li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
			<a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
			   asp-route-searchTitle="@Model.Filters.SearchTitle"
			   asp-route-location="@Model.Filters.Location"
			   asp-route-workType="@Model.Filters.WorkType"
			   asp-route-sortBy="@Model.Filters.SortBy">Previous</a>
		</li>

		@for (int i = 1; i <= Model.TotalPages; i++)
		{
			<li class="page-item @(i == Model.CurrentPage ? "active" : "")">
				<a class="page-link" asp-action="Index" asp-route-page="@i"
				   asp-route-searchTitle="@Model.Filters.SearchTitle"
				   asp-route-location="@Model.Filters.Location"
				   asp-route-workType="@Model.Filters.WorkType"
				   asp-route-sortBy="@Model.Filters.SortBy">@i</a>
			</li>
		}

		<li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
			<a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
			   asp-route-searchTitle="@Model.Filters.SearchTitle"
			   asp-route-location="@Model.Filters.Location"
			   asp-route-workType="@Model.Filters.WorkType"
			   asp-route-sortBy="@Model.Filters.SortBy">Next</a>
		</li>
	</ul>
</nav>

@section Scripts {
	<script>
		function deleteJobPosting(id) {
			if(confirm("Are you sure you want to delete this job posting?"))
			{
				$.ajax({
					url: "@Url.Action("Delete", "JobPostings")/" + id, //.../JobPostings/Delete/<id>
					type: "delete",
					success: function(result) {
						$("#job-posting-" + id).remove();
					},
					error: function(err) {
						alert(err)
					}
				});
			}
		}
	</script>
}